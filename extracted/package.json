{
  "name": "aristotle-autonomous-governance-os",
  "private": true,
  "version": "0.1.1",
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "services/*",
    "adapters/*",
    "shared/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm run dev -w @aristotle/shared-types\" \"npm run dev -w @aristotle/shared-schemas\" \"npm run dev -w @aristotle/governance-core\" \"npm run dev -w @aristotle/meta-authority-registry\" \"npm run dev -w @aristotle/policy-compiler\" \"npm run dev -w @aristotle/evidence-ledger\" \"npm run dev -w @aristotle/authority-router\" \"npm run dev -w @aristotle/witness-service\" \"npm run dev -w @aristotle/execution-gate\" \"npm run dev -w @aristotle/governance-kernel\" \"npm run dev -w @aristotle/simulation-engine\" \"npm run dev -w @aristotle/agent-os\" \"npm run dev -w @aristotle/http-gateway\" \"npm run dev -w @aristotle/console-ui\"",
    "local:up": "node scripts/local-control-plane.mjs up",
    "local:status": "node scripts/local-control-plane.mjs status",
    "local:down": "node scripts/local-control-plane.mjs down",
    "pilot:images": "node scripts/build-pilot-images.mjs",
    "pilot:install": "node scripts/pilot-install.mjs",
    "pilot:smoke": "node scripts/k8s-smoke-install.mjs",
    "pilot:smoke:kind": "node scripts/k8s-smoke-install.mjs --runtime kind",
    "pilot:smoke:minikube": "node scripts/k8s-smoke-install.mjs --runtime minikube",
    "aristotle": "tsx apps/aristotle-cli/src/index.ts",
    "aristotle:demo": "npm run dev -w @aristotle/console-ui -- --host 127.0.0.1 --port 4173",
    "execution-control:dev": "tsx apps/aristotle-cli/src/index.ts execution-control dev",
    "execution-control:serve": "tsx apps/aristotle-cli/src/index.ts execution-control serve --ward examples/execution_control/ward.montana_drone_test_range.yaml --envelope examples/execution_control/authority_envelope.survey_planner.yaml --ledger ./.tmp/execution-control-runtime.gel.jsonl",
    "execution-control:submit:allow": "tsx apps/aristotle-cli/src/index.ts execution-control submit --action examples/execution_control/actions/allow_takeoff.json --require-warrant",
    "execution-control:audit:verify": "tsx apps/aristotle-cli/src/index.ts execution-control audit verify --ledger ./.tmp/execution-control-runtime.gel.jsonl",
    "execution-control:evidence:demo": "tsx apps/aristotle-cli/src/index.ts execution-control evaluate --ward examples/execution_control/ward.montana_drone_test_range.yaml --envelope examples/execution_control/authority_envelope.survey_planner.yaml --action examples/execution_control/actions/allow_takeoff.json --ledger ./.tmp/execution-control-runtime.gel.jsonl --evidence-out ./.tmp/execution-control-evidence-bundle.json --now 2026-05-21T14:00:00.000Z",
    "execution-control:evidence:verify": "tsx apps/aristotle-cli/src/index.ts execution-control evidence verify --bundle ./.tmp/execution-control-evidence-bundle.json",
    "stack:up": "docker compose up --build -d",
    "stack:down": "docker compose down",
    "stack:logs": "docker compose logs -f",
    "stack:smoke": "node scripts/validate-stack.mjs",
    "enterprise:keys": "node scripts/generate-ledger-keypair.mjs",
    "enterprise:backup": "node scripts/backup-governance-state.mjs",
    "enterprise:restore": "node scripts/restore-governance-state.mjs --yes",
    "enterprise:drill": "node scripts/validate-recovery.mjs",
    "enterprise:contracts": "node scripts/validate-deployment-contracts.mjs",
    "enterprise:ui-safety": "node scripts/validate-console-safety.mjs",
    "enterprise:release-manifest": "node scripts/generate-release-manifest.mjs",
    "enterprise:preflight": "node scripts/validate-enterprise-config.mjs --production",
    "enterprise:verify": "npm run enterprise:preflight && npm run enterprise:contracts && npm run enterprise:ui-safety && npm run enterprise:release-manifest && npm run test:chain && npm run stack:verify",
    "enterprise:chain-keys": "node scripts/generate-chain-keypair.mjs",
    "stack:verify": "npm run stack:smoke && npm run validate:core && npm run validate:chain",
    "lint": "echo 'lint not yet configured'",
    "test": "npm run test:governance && npm run test:execution-control && npm run test:sandbox && npm run test:trace && npm run test:cli && npm run test:api && npm run test:chain && npm run test:adapters",
    "test:governance": "tsx shared/trial-engine/src/index.test.ts",
    "test:execution-control": "tsx shared/execution-control-runtime/src/index.test.ts",
    "test:sandbox": "tsx shared/execution-control-runtime/src/sandbox.test.ts",
    "test:trace": "tsx shared/execution-control-runtime/src/trace.test.ts",
    "test:cli": "npm run build -w @aristotle/trial-engine && npm run build -w @aristotle/execution-control-runtime && tsx apps/aristotle-cli/src/index.test.ts",
    "test:api": "tsx adapters/http-gateway/src/trial-api.contract.test.ts",
    "test:adapters": "tsx examples/framework-adapters/govern.test.ts",
    "test:playground": "npm run test:governance",
    "validate:core": "node scripts/validate-core.mjs",
    "validate:chain": "node scripts/validate-chain.mjs",
    "test:chain": "tsx shared/governance-core/src/test/run.test.ts && tsx services/governance-kernel/src/governance-chain.test.ts && tsx services/agent-os/src/governance-chain-client.test.ts && tsx adapters/http-gateway/src/governance-chain-proxy.test.ts",
    "benchmark:runtime": "tsx scripts/benchmark-runtime.ts",
    "bench:execution-control": "tsx shared/execution-control-runtime/benchmark.mts",
    "sbom": "node scripts/generate-sbom.mjs",
    "package:cli:check": "node scripts/check-cli-package.mjs",
    "clean-room": "node scripts/clean-room-scan.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.1",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"],
    "overrides": {
      "path-to-regexp@<0.1.13": "0.1.13",
      "qs@>=6.11.1 <=6.15.1": "^6.15.2"
    }
  }
}
