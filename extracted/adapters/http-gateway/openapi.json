{
  "openapi": "3.1.0",
  "info": {
    "title": "AristotleOS Ward/Warrant Execution-Control Path",
    "version": "0.1.1",
    "description": "AristotleOS-native execution-control boundary: Canonical Governed Action -> Commit Gate -> Warrant -> GEL.\n\nThis spec describes the substrate's HTTP contract as it is implemented by `shared/execution-control-runtime` and consumed by `@aristotle/os-sdk` (`AristotleClient`). The same client class also serves as the canonical typed client for this spec. The companion `@aristotle/gateway-client` package exports this spec as a JSON artifact for operators who want to feed it into their own OpenAPI tooling (openapi-generator, Stoplight, Insomnia, etc.) without depending on the full SDK.\n\nDoctrine: governance must bind at the execution boundary BEFORE irreversible state mutation or external action occurs. Every ALLOW carries a single-use signed Warrant; every decision is appended to the Governance Evidence Ledger (GEL) hash chain.",
    "contact": {
      "name": "AristotleOS",
      "url": "https://github.com/AristotleAgentic/AristotleOS"
    },
    "license": {
      "name": "MPL-2.0"
    }
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8181",
      "description": "Default local execution-control runtime port."
    },
    {
      "url": "https://gate.internal",
      "description": "Production placeholder; operators substitute their own base URL."
    }
  ],
  "security": [
    { "bearerAuth": [] },
    { "apiKeyAuth": [] }
  ],
  "tags": [
    { "name": "health",       "description": "Liveness / readiness / OpenAPI discovery." },
    { "name": "commit-gate",  "description": "Evaluate a governed action; on ALLOW, returns a single-use Warrant." },
    { "name": "evidence",     "description": "Governance Evidence Ledger (GEL): tail, integrity verification, export." },
    { "name": "governance",   "description": "Operator: compile / diff / explain a governance manifest." },
    { "name": "shadow",       "description": "Operator: observe-only profiling of proposed actions." },
    { "name": "reconcile",    "description": "Operator: reconcile offline edge decisions; manage the Conflict Inbox." },
    { "name": "approvals",    "description": "Operator: dual-control (M-of-N) approvals." },
    { "name": "marshal",      "description": "Operator: Ward Marshal census + behavior analytics." },
    { "name": "degradation",  "description": "Viewer: live degradation health + projected fail action." },
    { "name": "metrics",      "description": "Viewer: gate counters + reason-code histogram + ledger gauges." },
    { "name": "admin",        "description": "Admin: kill switch, revocation list." }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Runtime health + active governance context.",
        "security": [],
        "responses": {
          "200": {
            "description": "Runtime is healthy.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "tags": ["health"],
        "summary": "OpenAPI contract for the execution-control runtime.",
        "security": [],
        "responses": {
          "200": {
            "description": "OpenAPI 3 specification.",
            "content": { "application/json": { "schema": { "type": "object", "additionalProperties": true } } }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "tags": ["health"],
        "summary": "Prometheus exposition format: decision counters, reason-code histogram, ledger gauges.",
        "security": [],
        "responses": {
          "200": {
            "description": "Metrics in Prometheus text format.",
            "content": { "text/plain": { "schema": { "type": "string" } } }
          }
        }
      }
    },

    "/v1/execution-control/evaluate": {
      "post": {
        "tags": ["commit-gate"],
        "summary": "Evaluate a proposed governed action before execution.",
        "description": "The substrate's central operation. On ALLOW returns a single-use signed Warrant bound to the action's canonical hash; on REFUSE returns the reason codes; on ESCALATE returns the GEL record so the caller can route to a dual-control approval queue.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  { "$ref": "#/components/schemas/CanonicalAction" },
                  { "$ref": "#/components/schemas/EvaluateRequest" }
                ]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "ALLOW with Warrant.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EvaluateResponse" } } } },
          "202": { "description": "ESCALATE for missing state or policy ambiguity.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EvaluateResponse" } } } },
          "409": { "description": "REFUSE before execution.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EvaluateResponse" } } } }
        }
      }
    },
    "/v1/execution-control/proxy": {
      "post": {
        "tags": ["commit-gate"],
        "summary": "Evaluate AND forward downstream only on ALLOW (credentials brokered server-side).",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EvaluateRequest" } } }
        },
        "responses": {
          "200": { "description": "ALLOW and forwarded; downstream response included." },
          "202": { "description": "ESCALATE; not forwarded." },
          "409": { "description": "REFUSE; not forwarded." },
          "502": { "description": "ALLOW but downstream forwarding failed." }
        }
      }
    },
    "/v1/execution-control/replay": {
      "post": {
        "tags": ["commit-gate"],
        "summary": "Replay a historical decision against current policy (counterfactual).",
        "description": "Returns the same EvaluateResponse shape with `replay: true` so caller can audit drift between original-decision policy and current policy.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["record_id"],
                "properties": {
                  "record_id": { "type": "string", "description": "GEL record id of the original decision." },
                  "now": { "type": "string", "format": "date-time", "description": "Synthetic 'current time' for the replay; default = real now." }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Replay decision with replay: true.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EvaluateResponse" } } }
          }
        }
      }
    },
    "/v1/execution-control/evidence/export": {
      "post": {
        "tags": ["evidence"],
        "summary": "Export a signed Evidence Bundle for the given record range.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "from_seq": { "type": "integer", "minimum": 0 },
                  "to_seq":   { "type": "integer", "minimum": 0 },
                  "format":   { "type": "string", "enum": ["json", "bundle"] },
                  "exportedAt": { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Signed evidence bundle.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["bundle", "bundle_hash"],
                  "properties": {
                    "bundle": { "description": "Bundle payload (shape depends on format)." },
                    "bundle_hash": { "type": "string", "description": "sha256 of the canonical bundle bytes." }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/execution-control/warrant/verify": {
      "post": {
        "tags": ["commit-gate"],
        "summary": "Verify a Warrant's signature, expiry, single-use status, and binding hashes.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["warrant"],
                "properties": {
                  "warrant": { "type": "object", "description": "The Warrant payload to verify.", "additionalProperties": true },
                  "action":  { "$ref": "#/components/schemas/CanonicalAction", "description": "Optional canonical action to re-verify the parameters_hash / context_hash binding." },
                  "now":     { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification result.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["ok", "warrant_id", "signature_ok", "temporal_ok", "single_use_ok", "failures"],
                  "properties": {
                    "ok":             { "type": "boolean" },
                    "warrant_id":     { "type": "string" },
                    "signature_ok":   { "type": "boolean" },
                    "temporal_ok":    { "type": "boolean" },
                    "single_use_ok":  { "type": "boolean" },
                    "binding_ok":     { "type": "boolean" },
                    "failures":       { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/execution-control/warrant/inspect-chain": {
      "post": {
        "tags": ["commit-gate"],
        "summary": "Inspect MetaAuthorityEnvelope -> Ward -> AuthorityEnvelope -> Warrant chain.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["warrant_id"],
                "properties": { "warrant_id": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chain inspection result.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["warrant_id", "chain", "intact", "failures"],
                  "properties": {
                    "warrant_id": { "type": "string" },
                    "intact":     { "type": "boolean" },
                    "failures":   { "type": "array", "items": { "type": "string" } },
                    "chain": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["layer", "id", "issuer", "signer", "issued_at"],
                        "properties": {
                          "layer":     { "type": "string", "enum": ["mae", "ward", "envelope", "warrant"] },
                          "id":        { "type": "string" },
                          "issuer":    { "type": "string" },
                          "signer":    { "type": "string" },
                          "issued_at": { "type": "string", "format": "date-time" },
                          "expires_at":{ "type": "string", "format": "date-time" },
                          "revoked_at":{ "type": "string", "format": "date-time" },
                          "version":   { "type": "integer", "minimum": 0 }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/execution-control/context": {
      "get": {
        "tags": ["commit-gate"],
        "summary": "Viewer: the boundary's current Ward / AuthorityEnvelope context.",
        "responses": {
          "200": { "description": "Active governance context.", "content": { "application/json": { "schema": { "type": "object", "additionalProperties": true } } } }
        }
      }
    },

    "/v1/execution-control/audit/tail": {
      "get": {
        "tags": ["evidence"],
        "summary": "Return recent Governance Evidence Ledger records.",
        "parameters": [
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 1, "maximum": 1000, "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "Recent GEL records.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["items"],
                  "properties": {
                    "items": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/execution-control/audit/verify": {
      "get": {
        "tags": ["evidence"],
        "summary": "Verify the GEL hash-chain integrity end to end.",
        "responses": {
          "200": {
            "description": "Ledger verification result.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["ok", "count"],
                  "properties": {
                    "ok":      { "type": "boolean" },
                    "count":   { "type": "integer", "minimum": 0 },
                    "failure": { "type": "string", "description": "Present when ok=false." }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/execution-control/metrics": {
      "get": {
        "tags": ["metrics"],
        "summary": "JSON metrics snapshot (counters, latency, ledger height).",
        "responses": {
          "200": {
            "description": "Runtime metrics.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "warrants_today":     { "type": "integer" },
                    "refusals_today":     { "type": "integer" },
                    "escalations_today":  { "type": "integer" },
                    "gate_latency_ms":    { "type": "number" },
                    "ledger_height":      { "type": "integer" }
                  },
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
    "/v1/execution-control/degradation": {
      "get": {
        "tags": ["degradation"],
        "summary": "Viewer: live degradation status + projected fail action for this Ward.",
        "responses": {
          "200": {
            "description": "Degradation status.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["ward_id", "criticality", "healthy", "conditions", "fail_action", "probes"],
                  "properties": {
                    "ward_id":     { "type": "string" },
                    "criticality": { "type": "string", "enum": ["safety_critical", "mission_critical", "routine", "best_effort"] },
                    "healthy":     { "type": "boolean" },
                    "conditions":  {
                      "type": "array",
                      "items": { "type": "string", "enum": ["ledger_unavailable", "control_plane_stale", "quorum_lost", "dependency_timeout"] }
                    },
                    "fail_action": { "type": "string", "enum": ["allow", "allow_degraded", "escalate", "refuse"] },
                    "binding_condition": { "type": "string", "nullable": true, "enum": ["ledger_unavailable", "control_plane_stale", "quorum_lost", "dependency_timeout"] },
                    "probes":      { "type": "integer", "minimum": 0 }
                  }
                }
              }
            }
          }
        }
      }
    },

    "/v1/execution-control/governance/compile": {
      "post": {
        "tags": ["governance"],
        "summary": "Operator: compile a Ward + AuthorityEnvelope into a content-addressed manifest.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ward":               { "type": "object", "additionalProperties": true },
                  "authority_envelope": { "type": "object", "additionalProperties": true },
                  "now":                { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Compiled manifest with hash.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GovernanceManifest" } } }
          },
          "403": { "description": "Requires operator role." }
        }
      }
    },
    "/v1/execution-control/governance/diff": {
      "post": {
        "tags": ["governance"],
        "summary": "Operator: diff two governance manifests; flag weakening changes that require review.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["before", "after"],
                "properties": {
                  "before": { "type": "object", "additionalProperties": true },
                  "after":  { "type": "object", "additionalProperties": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Structured diff.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GovernanceDiffResult" } } }
          },
          "403": { "description": "Requires operator role." }
        }
      }
    },
    "/v1/execution-control/governance/explain": {
      "post": {
        "tags": ["governance"],
        "summary": "Operator: explain how sample actions resolve under a policy through the real Commit Gate.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ward":               { "type": "object", "additionalProperties": true },
                  "authority_envelope": { "type": "object", "additionalProperties": true },
                  "sample_actions":     { "type": "array", "items": { "$ref": "#/components/schemas/CanonicalAction" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Per-sample decisions.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PolicyExplanation" } } }
          },
          "403": { "description": "Requires operator role." }
        }
      }
    },

    "/v1/execution-control/shadow": {
      "post": {
        "tags": ["shadow"],
        "summary": "Operator: observe-only profiling of proposed actions; never mutates the live system.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["actions"],
                "properties": {
                  "actions":            { "type": "array", "items": { "$ref": "#/components/schemas/CanonicalAction" } },
                  "ward":               { "type": "object", "additionalProperties": true },
                  "authority_envelope": { "type": "object", "additionalProperties": true },
                  "now":                { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shadow report with would-decisions and rollout readiness.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ShadowReport" } } }
          },
          "403": { "description": "Requires operator role." }
        }
      }
    },

    "/v1/execution-control/reconcile": {
      "post": {
        "tags": ["reconcile"],
        "summary": "Operator: reconcile offline edge decisions against current/execution-time policy.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["records"],
                "properties": {
                  "records":            { "type": "array", "items": { "type": "object", "additionalProperties": true } },
                  "ward":               { "type": "object", "additionalProperties": true },
                  "authority_envelope": { "type": "object", "additionalProperties": true },
                  "now":                { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reconciliation report.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReconciliationReport" } } }
          }
        }
      }
    },
    "/v1/execution-control/conflicts/ingest": {
      "post": {
        "tags": ["reconcile"],
        "summary": "Operator: ingest edge records into the durable Conflict Inbox (idempotent).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["records"],
                "properties": {
                  "records":            { "type": "array", "items": { "type": "object", "additionalProperties": true } },
                  "ward":               { "type": "object", "additionalProperties": true },
                  "authority_envelope": { "type": "object", "additionalProperties": true },
                  "now":                { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reconciliation report + inbox summary.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["report", "summary"],
                  "properties": {
                    "report":  { "$ref": "#/components/schemas/ReconciliationReport" },
                    "summary": { "$ref": "#/components/schemas/ConflictSummary" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/execution-control/conflicts": {
      "get": {
        "tags": ["reconcile"],
        "summary": "Viewer: list current Conflict Inbox items + summary.",
        "responses": {
          "200": {
            "description": "Inbox items + summary.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["items", "summary"],
                  "properties": {
                    "items":   { "type": "array", "items": { "type": "object", "additionalProperties": true } },
                    "summary": { "$ref": "#/components/schemas/ConflictSummary" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/execution-control/conflicts/resolve": {
      "post": {
        "tags": ["reconcile"],
        "summary": "Operator: apply an attributed resolution to a conflict.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action_id", "action"],
                "properties": {
                  "action_id": { "type": "string" },
                  "action":    { "type": "string", "enum": ["accept", "reject", "escalate", "reconcile"] },
                  "reason":    { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated item + summary." },
          "400": { "description": "Invalid resolution." },
          "403": { "description": "Requires operator role." },
          "409": { "description": "Item unknown or already resolved." }
        }
      }
    },

    "/v1/execution-control/approvals": {
      "get": {
        "tags": ["approvals"],
        "summary": "Viewer: list dual-control approval requests.",
        "responses": {
          "200": {
            "description": "Approval requests + pending count.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["items"],
                  "properties": {
                    "items": { "type": "array", "items": { "$ref": "#/components/schemas/ApprovalItem" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/execution-control/approvals/decide": {
      "post": {
        "tags": ["approvals"],
        "summary": "Operator: cast an attributed approve/reject vote.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["request_id", "decision"],
                "properties": {
                  "request_id": { "type": "string" },
                  "decision":   { "type": "string", "enum": ["approve", "reject"] },
                  "reason":     { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated approval request." },
          "400": { "description": "Invalid vote." },
          "403": { "description": "Requires operator role." },
          "409": { "description": "Already resolved / self-approval / duplicate vote." }
        }
      }
    },

    "/v1/execution-control/marshal/census": {
      "post": {
        "tags": ["marshal"],
        "summary": "Operator: Ward Marshal census — risk-score observed agents against the approved registry.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["observations"],
                "properties": {
                  "observations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
                  "registry":     { "type": "object", "additionalProperties": true },
                  "now":          { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Census report with rogue/governed findings." },
          "403": { "description": "Requires operator role." }
        }
      }
    },
    "/v1/execution-control/marshal/behavior": {
      "post": {
        "tags": ["marshal"],
        "summary": "Operator: Ward Marshal behavioral analysis over a governance event stream.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["events"],
                "properties": {
                  "events": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
                  "config": { "type": "object", "additionalProperties": true },
                  "now":    { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Behavior report with detector findings." },
          "403": { "description": "Requires operator role." }
        }
      }
    },

    "/v1/execution-control/admin/kill": {
      "post": {
        "tags": ["admin"],
        "summary": "Admin: engage/disengage the sovereign-halt kill switch.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["engaged"],
                "properties": {
                  "engaged": { "type": "boolean" },
                  "reason":  { "type": "string" },
                  "scope":   { "type": "string" },
                  "action":  { "type": "string", "enum": ["arm", "disarm", "pause"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Kill-switch state updated." },
          "401": { "description": "Unauthenticated." },
          "403": { "description": "Requires admin role / auth not configured." },
          "409": { "description": "Kill switch path not configured." }
        }
      }
    },
    "/v1/execution-control/admin/revoke": {
      "post": {
        "tags": ["admin"],
        "summary": "Admin: add a revocation (key/envelope/warrant) to the revocation list.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["kind", "id"],
                "properties": {
                  "kind":   { "type": "string", "enum": ["key", "envelope", "warrant"] },
                  "id":     { "type": "string" },
                  "reason": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Revocation recorded." },
          "400": { "description": "Invalid revocation." },
          "401": { "description": "Unauthenticated." },
          "403": { "description": "Requires admin role / auth not configured." },
          "409": { "description": "Revocation list not configured." }
        }
      }
    }
  },

  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Operator credential: role-scoped static token, admin API key, or OIDC JWT. When any auth method is configured, /v1 routes require it (viewer < operator < admin)."
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Alternative header for the same operator credential."
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["ok"],
        "properties": {
          "ok":                       { "type": "boolean" },
          "runtime":                  { "type": "string" },
          "doctrine":                 { "type": "string" },
          "ward_id":                  { "type": "string" },
          "authority_envelope_id":    { "type": "string" },
          "kill_switch_engaged":      { "type": "boolean" },
          "replay_protection":        { "type": "boolean" },
          "auth_required":            { "type": "boolean" },
          "auth_methods": {
            "type": "object",
            "properties": {
              "api_key":         { "type": "boolean" },
              "operator_tokens": { "type": "boolean" },
              "oidc":            { "type": "boolean" }
            }
          }
        }
      },

      "EvaluateRequest": {
        "type": "object",
        "required": ["action"],
        "properties": {
          "action":           { "$ref": "#/components/schemas/CanonicalAction" },
          "runtime_register": { "type": "object", "additionalProperties": true },
          "now":              { "type": "string", "format": "date-time" }
        }
      },
      "CanonicalAction": {
        "description": "The canonical governed action: every field a Warrant binds to. Equivalent to @aristotle/os-sdk CanonicalAction. Additional fields are tolerated.",
        "type": "object",
        "required": ["action_id", "ward_id", "subject", "action_type"],
        "properties": {
          "action_id":    { "type": "string" },
          "ward_id":      { "type": "string" },
          "subject":      { "type": "string" },
          "action_type":  { "type": "string" },
          "target":       { "type": "string" },
          "params":       { "type": "object", "additionalProperties": true },
          "requested_at": { "type": "string", "format": "date-time" },
          "request_id":   { "type": "string" },
          "nonce":        { "type": "string" },
          "telemetry":    { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      },
      "EvaluateResponse": {
        "description": "The gate's decision; ALLOW carries a single-use signed Warrant. Equivalent to @aristotle/os-sdk EvaluateResponse.",
        "type": "object",
        "required": ["decision", "reason_codes", "canonical_action_hash", "gel_record"],
        "properties": {
          "decision":               { "type": "string", "enum": ["ALLOW", "REFUSE", "ESCALATE", "EXPIRE"] },
          "reason_codes":           { "type": "array", "items": { "type": "string" } },
          "canonical_action_hash":  { "type": "string", "description": "sha256 of the canonical action." },
          "warrant": {
            "type": "object",
            "required": ["warrant_id"],
            "properties": {
              "warrant_id":     { "type": "string" },
              "issued_at":      { "type": "string", "format": "date-time" },
              "expires_at":     { "type": "string", "format": "date-time" },
              "single_use":     { "type": "boolean" },
              "signature":      { "type": "string" },
              "signing_key_id": { "type": "string" }
            },
            "additionalProperties": true
          },
          "gel_record": {
            "type": "object",
            "required": ["record_id", "record_hash"],
            "properties": {
              "record_id":   { "type": "string" },
              "record_hash": { "type": "string" }
            },
            "additionalProperties": true
          },
          "replay": { "type": "boolean", "description": "Set true by /v1/execution-control/replay." }
        },
        "additionalProperties": true
      },

      "GovernanceManifest": {
        "type": "object",
        "required": ["manifest_version", "hashes", "validation"],
        "properties": {
          "manifest_version": { "type": "string" },
          "hashes": {
            "type": "object",
            "required": ["ward_hash", "authority_envelope_hash", "manifest_hash"],
            "properties": {
              "ward_hash":               { "type": "string" },
              "authority_envelope_hash": { "type": "string" },
              "manifest_hash":           { "type": "string" }
            }
          },
          "validation": {
            "type": "object",
            "required": ["ok", "errors"],
            "properties": {
              "ok":     { "type": "boolean" },
              "errors": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "additionalProperties": true
      },
      "GovernanceDiffResult": {
        "type": "object",
        "required": ["entries", "summary"],
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "kind", "weakening", "note"],
              "properties": {
                "path":      { "type": "string" },
                "kind":      { "type": "string" },
                "weakening": { "type": "boolean" },
                "note":      { "type": "string" }
              },
              "additionalProperties": true
            }
          },
          "summary": {
            "type": "object",
            "required": ["total", "weakening", "requires_review"],
            "properties": {
              "total":           { "type": "integer", "minimum": 0 },
              "weakening":       { "type": "integer", "minimum": 0 },
              "requires_review": { "type": "boolean" }
            }
          }
        }
      },
      "PolicyExplanation": {
        "type": "object",
        "required": ["ward_id", "authority_envelope_id", "allowed_actions", "denied_actions", "samples"],
        "properties": {
          "ward_id":               { "type": "string" },
          "authority_envelope_id": { "type": "string" },
          "allowed_actions":       { "type": "array", "items": { "type": "string" } },
          "denied_actions":        { "type": "array", "items": { "type": "string" } },
          "samples": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["action_id", "action_type", "decision", "reason_codes"],
              "properties": {
                "action_id":    { "type": "string" },
                "action_type":  { "type": "string" },
                "decision":     { "type": "string", "enum": ["ALLOW", "REFUSE", "ESCALATE", "EXPIRE"] },
                "reason_codes": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "additionalProperties": true
      },

      "ShadowReport": {
        "type": "object",
        "required": ["ward_id", "authority_envelope_id", "count", "decisions", "rollout"],
        "properties": {
          "ward_id":               { "type": "string" },
          "authority_envelope_id": { "type": "string" },
          "count":                 { "type": "integer", "minimum": 0 },
          "decisions": {
            "type": "object",
            "additionalProperties": { "type": "integer", "minimum": 0 }
          },
          "rollout": {
            "type": "object",
            "required": ["ready", "allow_rate"],
            "properties": {
              "ready":      { "type": "boolean" },
              "allow_rate": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        },
        "additionalProperties": true
      },

      "ReconciliationReport": {
        "type": "object",
        "required": ["ward_id", "count", "agreements", "conflicts", "items"],
        "properties": {
          "ward_id":    { "type": "string" },
          "count":      { "type": "integer", "minimum": 0 },
          "agreements": { "type": "integer", "minimum": 0 },
          "conflicts":  { "type": "integer", "minimum": 0 },
          "items":      { "type": "array", "items": { "type": "object", "additionalProperties": true } }
        },
        "additionalProperties": true
      },
      "ConflictSummary": {
        "type": "object",
        "required": ["total", "open", "conflicts", "by_status"],
        "properties": {
          "total":     { "type": "integer", "minimum": 0 },
          "open":      { "type": "integer", "minimum": 0 },
          "conflicts": { "type": "integer", "minimum": 0 },
          "by_status": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
        }
      },

      "ApprovalItem": {
        "type": "object",
        "required": ["request_id", "action_id", "action_type", "ward_id", "required", "votes", "status", "created_at"],
        "properties": {
          "request_id":  { "type": "string" },
          "action_id":   { "type": "string" },
          "action_type": { "type": "string" },
          "ward_id":     { "type": "string" },
          "required":    { "type": "integer", "minimum": 1 },
          "status":      { "type": "string", "enum": ["pending", "approved", "rejected"] },
          "created_at":  { "type": "string", "format": "date-time" },
          "votes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["operator_id", "decision", "voted_at"],
              "properties": {
                "operator_id": { "type": "string" },
                "decision":    { "type": "string", "enum": ["approve", "reject"] },
                "reason":      { "type": "string" },
                "voted_at":    { "type": "string", "format": "date-time" }
              }
            }
          }
        },
        "additionalProperties": true
      }
    }
  }
}
