# --- GOVERNANCE_CHAIN_V2 (Ward/Warrant runtime authority chain) ---
# Opt-in. When true, governance-kernel registers the /v2/* chain routes
# (Meta Authority Envelope -> Ward -> Authority Envelope -> Warrant ->
# Commit Gate -> GEL Record). Off by default; the legacy kernel surface is
# unaffected either way.
GOVERNANCE_CHAIN_V2=false
# HMAC secret the kernel signs MAE/Ward/Envelope/Warrant and GEL records with.
# Required for any non-dev use of the chain; a dev fallback is used if unset.
GOVERNANCE_CHAIN_SIGNING_SECRET=
# Key id recorded on signatures (defaults to "governance-kernel-key").
GOVERNANCE_CHAIN_KEY_ID=
# Durable state file for the chain (MAE/Ward/Envelope/Warrant + GEL ledger +
# consumed-nonce set). Without it the chain is in-memory and a kernel restart
# drops the audit trail. Relative paths resolve from the kernel's cwd.
GOVERNANCE_CHAIN_STATE_PATH=./data/governance-chain.json
# agent-os behaviour when GOVERNANCE_CHAIN_V2=true:
#   shadow  = run the Ward/Warrant chain and record the decision, never gate (default)
#   enforce = a non-Allow chain decision (or an unreachable kernel) blocks the act
GOVERNANCE_CHAIN_MODE=shadow
