NODE_ENV=production
SERVICE_DISCOVERY_MODE=container
ALLOW_INSECURE_PRODUCTION_BOOT=false

PORT_GATEWAY=8080
PORT_GOVERNANCE_KERNEL=7001
PORT_POLICY_COMPILER=7002
PORT_EVIDENCE_LEDGER=7003
PORT_META_AUTHORITY_REGISTRY=7004
PORT_SIMULATION_ENGINE=7005
PORT_AUTHORITY_ROUTER=7006
PORT_WITNESS_SERVICE=7007
PORT_EXECUTION_GATE=7008
PORT_AGENT_OS=7009

OPERATOR_API_KEY=replace-with-strong-secret
OPERATOR_SESSION_ENFORCEMENT=true
OPERATOR_SESSION_SECRET=replace-with-strong-session-secret
OPERATOR_SESSION_TTL_MS=900000
OPERATOR_SESSION_SKEW_MS=60000
OPERATOR_ROLE_ENFORCEMENT=true
OPERATOR_DEFAULT_ROLE=operator
OPERATOR_READ_ROLES=viewer,operator,admin
OPERATOR_MUTATION_ROLES=operator,admin
OPERATOR_READ_ACTORS=enterprise-console,enterprise-validation
OPERATOR_MUTATION_ACTORS=enterprise-console,enterprise-validation

VITE_OPERATOR_API_KEY=replace-with-strong-secret
VITE_OPERATOR_ACTOR=enterprise-console
VITE_OPERATOR_ROLE=operator
OPERATOR_ACTOR=enterprise-validation
OPERATOR_ROLE=operator

GOVERNANCE_CHAIN_V2=true
GOVERNANCE_CHAIN_MODE=enforce
GOVERNANCE_CHAIN_KEY_ID=governance-kernel-production
GOVERNANCE_CHAIN_STATE_PATH=./data/governance-chain.json
GOVERNANCE_CHAIN_SIGNING_SECRET=replace-with-strong-chain-signing-secret
GOVERNANCE_CHAIN_SIGNING_PRIVATE_KEY_PATH=
GOVERNANCE_CHAIN_SIGNING_PUBLIC_KEY_PATH=

LEDGER_DB_PATH=./data/evidence-ledger.sqlite
EVIDENCE_LEDGER_STATE_PATH=./data/evidence-ledger.json
EVIDENCE_LEDGER_SIGNING_SECRET=replace-with-strong-ledger-signing-secret
EVIDENCE_LEDGER_SIGNING_PRIVATE_KEY_PATH=
EVIDENCE_LEDGER_SIGNING_PUBLIC_KEY_PATH=
EVIDENCE_LEDGER_SIGNER=evidence-ledger.production
AGENT_OS_STATE_PATH=./data/agent-os.json

REPLAY_TICK_MS=1500
WITNESS_QUORUM=2
KILL_SWITCH_DEFAULT=inactive
AGENT_OS_HEARTBEAT_TIMEOUT_MS=300000
AGENT_OS_LEASE_RENEWAL_WINDOW_MS=900000
AGENT_OS_LEASE_EXTENSION_MS=1800000
AGENT_OS_TASK_MAX_ATTEMPTS=3

OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.monitoring.svc.cluster.local:4318
OTEL_SERVICE_NAME=aristotle-http-gateway
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,service.namespace=aristotle-governance-os
SPIFFE_TRUST_DOMAIN=cluster.local
SPIFFE_SOCKET_PATH=/run/spire/sockets/spire-agent.sock
