{
  "name": "@aristotle/opcua-adapter",
  "version": "0.1.0",
  "description": "Govern OPC-UA node writes + method calls with AristotleOS. The same FlightControlTransport / RosControlTransport shape, applied to industrial automation.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "files": ["dist", "README.md", "LICENSE", "NOTICE"],
  "keywords": ["aristotle", "opc-ua", "industrial", "scada", "agent-governance"],
  "homepage": "https://github.com/AristotleAgentic/AristotleOS",
  "repository": { "type": "git", "url": "https://github.com/AristotleAgentic/AristotleOS.git", "directory": "packages/opcua-adapter" },
  "bugs": { "url": "https://github.com/AristotleAgentic/AristotleOS/issues" },
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=18" },
  "sideEffects": false,
  "dependencies": {
    "@aristotle/os-sdk": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/index.test.ts",
    "prepublishOnly": "npm run build"
  }
}
