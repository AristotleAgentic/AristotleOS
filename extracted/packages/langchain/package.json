{
  "name": "@aristotle/langchain",
  "version": "0.1.0",
  "description": "Govern LangChain.js tool invocations with AristotleOS. Drop-in wrapper that routes every tool call through the execution-control Commit Gate before it runs.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "aristotle",
    "aristotleos",
    "langchain",
    "langchainjs",
    "agent-governance",
    "ai-governance",
    "tool-call-gate",
    "commit-gate"
  ],
  "homepage": "https://github.com/AristotleAgentic/AristotleOS",
  "repository": {
    "type": "git",
    "url": "https://github.com/AristotleAgentic/AristotleOS.git",
    "directory": "packages/langchain"
  },
  "bugs": {
    "url": "https://github.com/AristotleAgentic/AristotleOS/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "dependencies": {
    "@aristotle/os-sdk": "workspace:*"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0 <1.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/index.test.ts",
    "prepublishOnly": "npm run build"
  }
}
