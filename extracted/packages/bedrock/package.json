{
  "name": "@aristotle/bedrock",
  "version": "0.1.0",
  "description": "Govern AWS Bedrock Converse-API tool calls with AristotleOS. Drop-in dispatcher that routes every toolUse block through the execution-control Commit Gate before your tool function runs.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "files": ["dist", "README.md", "LICENSE", "NOTICE"],
  "keywords": ["aristotle", "bedrock", "aws-bedrock", "converse", "ai-governance", "agent-governance", "commit-gate"],
  "homepage": "https://github.com/AristotleAgentic/AristotleOS",
  "repository": {"type": "git", "url": "https://github.com/AristotleAgentic/AristotleOS.git", "directory": "packages/bedrock"},
  "bugs": {"url": "https://github.com/AristotleAgentic/AristotleOS/issues"},
  "publishConfig": {"access": "public"},
  "engines": {"node": ">=18"},
  "sideEffects": false,
  "dependencies": {"@aristotle/os-sdk": "workspace:*"},
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/index.test.ts",
    "prepublishOnly": "npm run build"
  }
}
