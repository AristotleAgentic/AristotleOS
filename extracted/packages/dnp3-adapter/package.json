{
  "name": "@aristotle/dnp3-adapter",
  "version": "0.1.0",
  "description": "Govern DNP3 outstation control writes with AristotleOS. The hardware-governance pattern applied to electric-grid SCADA / RTU communication.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "files": ["dist", "README.md", "LICENSE", "NOTICE"],
  "keywords": ["aristotle", "dnp3", "grid", "scada", "rtu", "agent-governance"],
  "homepage": "https://github.com/AristotleAgentic/AristotleOS",
  "repository": { "type": "git", "url": "https://github.com/AristotleAgentic/AristotleOS.git", "directory": "packages/dnp3-adapter" },
  "bugs": { "url": "https://github.com/AristotleAgentic/AristotleOS/issues" },
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=18" },
  "sideEffects": false,
  "dependencies": { "@aristotle/os-sdk": "workspace:*" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/index.test.ts",
    "prepublishOnly": "npm run build"
  }
}
