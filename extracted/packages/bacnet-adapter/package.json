{
  "name": "@aristotle/bacnet-adapter",
  "version": "0.1.0",
  "description": "Govern BACnet/IP WriteProperty and WritePropertyMultiple operations with AristotleOS. The hardware-governance pattern applied to building automation: HVAC, lighting, access, fire systems.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "files": ["dist", "README.md", "LICENSE", "NOTICE"],
  "keywords": ["aristotle", "bacnet", "building-automation", "hvac", "ot", "agent-governance"],
  "homepage": "https://github.com/AristotleAgentic/aristotle-os",
  "repository": { "type": "git", "url": "https://github.com/AristotleAgentic/aristotle-os.git", "directory": "packages/bacnet-adapter" },
  "bugs": { "url": "https://github.com/AristotleAgentic/aristotle-os/issues" },
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=18" },
  "sideEffects": false,
  "dependencies": {
    "@aristotle/adapter-sdk": "workspace:*",
    "@aristotle/os-sdk": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/index.test.ts",
    "prepublishOnly": "npm run build"
  }
}
