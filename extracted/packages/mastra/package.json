{
  "name": "@aristotle/mastra",
  "version": "0.1.0",
  "description": "Govern Mastra tool calls with AristotleOS. Wraps a Mastra Tool's execute so every invocation routes through the execution-control Commit Gate before it runs.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "files": ["dist", "README.md", "LICENSE", "NOTICE"],
  "keywords": ["aristotle", "mastra", "ai-governance", "agent-governance", "commit-gate"],
  "homepage": "https://github.com/AristotleAgentic/AristotleOS",
  "repository": {"type": "git", "url": "https://github.com/AristotleAgentic/AristotleOS.git", "directory": "packages/mastra"},
  "bugs": {"url": "https://github.com/AristotleAgentic/AristotleOS/issues"},
  "publishConfig": {"access": "public"},
  "engines": {"node": ">=18"},
  "sideEffects": false,
  "dependencies": {"@aristotle/os-sdk": "workspace:*"},
  "peerDependencies": {"@mastra/core": ">=0.1.0 <2.0.0"},
  "peerDependenciesMeta": {"@mastra/core": {"optional": true}},
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/index.test.ts",
    "prepublishOnly": "npm run build"
  }
}
