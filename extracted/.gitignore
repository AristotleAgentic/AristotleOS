# Build output co-located with sources (tsc emits next to .ts when
# the package's tsconfig has no outDir). Tracked .js/.d.ts files
# already in the index stay; new emissions stay out.
shared/execution-control-runtime/src/*.js
shared/execution-control-runtime/src/*.d.ts
shared/execution-control-runtime/src/*.d.ts.map
shared/execution-control-runtime/src/*.js.map
